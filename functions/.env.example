# Copy this file to `.env` (same folder) and fill in the values.
# These are NON-SECRET params. The secret keys are set separately with
# `firebase functions:secrets:set` (see SETUP.md) — do NOT put them here.

# From Billplz dashboard → Billing → your Collection.
BILLPLZ_COLLECTION_ID=

# The deployed billplzCallback URL. You only know this AFTER the first deploy,
# so: deploy once, copy the printed billplzCallback URL here, then deploy again.
BILLPLZ_CALLBACK_URL=
